<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <changeSet author="crediblex" id="1" context="postgresql">
        <sql>
            WITH duplicates AS (
            SELECT
            id,
            ROW_NUMBER() OVER (
            PARTITION BY product_id, product_type, financial_account_type
            ORDER BY id
            ) AS rn
            FROM acc_product_mapping
            WHERE financial_account_type = 23
            )
            DELETE FROM acc_product_mapping
            WHERE id IN (
            SELECT id
            FROM duplicates
            WHERE rn > 1
            );
        </sql>
    </changeSet>

    <!-- Drop the overly strict balance consistency constraint that's preventing LOC updates -->
    <changeSet author="crediblex" id="2" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <sqlCheck expectedResult="1">
                    SELECT COUNT(*) FROM information_schema.table_constraints
                    WHERE constraint_name = 'chk_loc_balance_consistency'
                    AND table_name = 'm_line_of_credit'
                </sqlCheck>
            </and>
        </preConditions>
        <comment>Drop balance consistency constraint as it's too strict and doesn't account for complex business logic like fees, interest, and partial repayments</comment>
        <sql>
            ALTER TABLE m_line_of_credit DROP CONSTRAINT IF EXISTS chk_loc_balance_consistency;
        </sql>
    </changeSet>

</databaseChangeLog>
