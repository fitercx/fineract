<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="0042-add-los-external-id-to-approved-buyers" author="system">
        <comment>Add losExternalId column to m_line_of_credit_approved_buyers table</comment>
        
        <addColumn tableName="m_line_of_credit_approved_buyers">
            <column name="los_external_id" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        
        <rollback>
            <dropColumn tableName="m_line_of_credit_approved_buyers" columnName="los_external_id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>