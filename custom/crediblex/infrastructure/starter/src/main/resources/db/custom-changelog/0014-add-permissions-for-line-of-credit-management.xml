<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0012-add-permissions-for-line-of-credit-management" author="crediblex">
        <comment>Add Line of Credit permissions</comment>
        
        <!-- Line of Credit permissions -->
        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="CREATE_LINE_OF_CREDIT"/>
            <column name="entity_name" value="LINE_OF_CREDIT"/>
            <column name="action_name" value="CREATE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>

        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="UPDATE_LINE_OF_CREDIT"/>
            <column name="entity_name" value="LINE_OF_CREDIT"/>
            <column name="action_name" value="UPDATE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>

        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="DELETE_LINE_OF_CREDIT"/>
            <column name="entity_name" value="LINE_OF_CREDIT"/>
            <column name="action_name" value="DELETE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>

        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="READ_LINE_OF_CREDIT"/>
            <column name="entity_name" value="LINE_OF_CREDIT"/>
            <column name="action_name" value="READ"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>

        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="ACTIVATE_LINE_OF_CREDIT"/>
            <column name="entity_name" value="LINE_OF_CREDIT"/>
            <column name="action_name" value="ACTIVATE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>

        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="DEACTIVATE_LINE_OF_CREDIT"/>
            <column name="entity_name" value="LINE_OF_CREDIT"/>
            <column name="action_name" value="DEACTIVATE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>

    </changeSet>

</databaseChangeLog>
