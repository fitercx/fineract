<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!-- Create m_line_of_credit table for MySQL -->
    <changeSet author="crediblex" id="1" context="mysql">
        <createTable tableName="m_line_of_credit">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="client_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="maximum_amount" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="available_balance" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="consumed_amount" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="activation_status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="created_on_utc" type="DATETIME"/>
            <column name="created_by" type="BIGINT"/>
            <column name="last_modified_on_utc" type="DATETIME"/>
            <column name="last_modified_by" type="BIGINT"/>
        </createTable>
    </changeSet>

    <!-- Create m_line_of_credit table for PostgreSQL -->
    <changeSet author="crediblex" id="1" context="postgresql">
        <createTable tableName="m_line_of_credit">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="client_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="maximum_amount" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="available_balance" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="consumed_amount" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="activation_status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="created_on_utc" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_by" type="BIGINT"/>
            <column name="last_modified_on_utc" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="last_modified_by" type="BIGINT"/>
        </createTable>
    </changeSet>

    <!-- Create m_line_of_credit_transactions table for MySQL -->
    <changeSet author="crediblex" id="2" context="mysql">
        <createTable tableName="m_line_of_credit_transactions">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="line_of_credit_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="balance_before" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="balance_after" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="reference_number" type="VARCHAR(100)"/>
            <column name="description" type="VARCHAR(500)"/>
            <column name="created_on_utc" type="DATETIME"/>
            <column name="created_by" type="BIGINT"/>
            <column name="last_modified_on_utc" type="DATETIME"/>
            <column name="last_modified_by" type="BIGINT"/>
        </createTable>
    </changeSet>

    <!-- Create m_line_of_credit_transactions table for PostgreSQL -->
    <changeSet author="crediblex" id="2" context="postgresql">
        <createTable tableName="m_line_of_credit_transactions">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="line_of_credit_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="balance_before" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="balance_after" type="DECIMAL(19,6)">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_date" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="reference_number" type="VARCHAR(100)"/>
            <column name="description" type="VARCHAR(500)"/>
            <column name="created_on_utc" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_by" type="BIGINT"/>
            <column name="last_modified_on_utc" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="last_modified_by" type="BIGINT"/>
        </createTable>
    </changeSet>

    <!-- Add foreign key constraints -->
    <changeSet author="crediblex" id="3">
        <addForeignKeyConstraint baseColumnNames="client_id" baseTableName="m_line_of_credit"
                                 constraintName="FK_line_of_credit_client" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_client" validate="true"/>
        
        <addForeignKeyConstraint baseColumnNames="line_of_credit_id" baseTableName="m_line_of_credit_transactions"
                                 constraintName="FK_line_of_credit_transactions_line_of_credit" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_line_of_credit" validate="true"/>
        
        <addForeignKeyConstraint baseColumnNames="created_by" baseTableName="m_line_of_credit"
                                 constraintName="FK_line_of_credit_created_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        
        <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="m_line_of_credit"
                                 constraintName="FK_line_of_credit_last_modified_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        
        <addForeignKeyConstraint baseColumnNames="created_by" baseTableName="m_line_of_credit_transactions"
                                 constraintName="FK_line_of_credit_transactions_created_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
        
        <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="m_line_of_credit_transactions"
                                 constraintName="FK_line_of_credit_transactions_last_modified_by" deferrable="false" initiallyDeferred="false"
                                 onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="id"
                                 referencedTableName="m_appuser" validate="true"/>
    </changeSet>

    <!-- Add indexes for better performance -->
    <changeSet author="crediblex" id="4">
        <createIndex tableName="m_line_of_credit" indexName="idx_line_of_credit_client_id">
            <column name="client_id"/>
        </createIndex>
        
        <createIndex tableName="m_line_of_credit" indexName="idx_line_of_credit_activation_status">
            <column name="activation_status"/>
        </createIndex>
        
        <createIndex tableName="m_line_of_credit_transactions" indexName="idx_line_of_credit_transactions_line_of_credit_id">
            <column name="line_of_credit_id"/>
        </createIndex>
        
        <createIndex tableName="m_line_of_credit_transactions" indexName="idx_line_of_credit_transactions_transaction_date">
            <column name="transaction_date"/>
        </createIndex>
        
        <createIndex tableName="m_line_of_credit_transactions" indexName="idx_line_of_credit_transactions_transaction_type">
            <column name="transaction_type"/>
        </createIndex>
    </changeSet>

</databaseChangeLog> 