<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2" author="crediblex">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0"> Select count(1) from m_permission where code = 'READ_LOC_CHARGE'</sqlCheck>
        </preConditions>

        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="READ_LOC_CHARGE"/>
            <column name="entity_name" value="LOC_CHARGE"/>
            <column name="action_name" value="READ"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="WAIVE_LOC_CHARGE"/>
            <column name="entity_name" value="LOC_CHARGE"/>
            <column name="action_name" value="WAIVE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="DELETE_LOC_CHARGE"/>
            <column name="entity_name" value="LOC_CHARGE"/>
            <column name="action_name" value="DELETE"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>
</databaseChangeLog>
