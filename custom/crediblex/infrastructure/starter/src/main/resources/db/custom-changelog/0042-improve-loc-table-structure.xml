    <!-- Add composite index for transaction queries (line_of_credit_id + transaction_date) -->
    <changeSet author="crediblex" id="2" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <not>
                    <indexExists tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_loc_id_date"/>
                </not>
            </and>
        </preConditions>
        <comment>Add composite index for efficient transaction history queries by LOC and date</comment>
        <createIndex tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_loc_id_date">
            <column name="line_of_credit_id"/>
            <column name="transaction_date" descending="true"/>
        </createIndex>
    </changeSet>

    <!-- Add index on transaction_type + line_of_credit_id for filtering by transaction type -->
    <changeSet author="crediblex" id="3" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <not>
                    <indexExists tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_type_loc_id"/>
                </not>
            </and>
        </preConditions>
        <comment>Add composite index for filtering transactions by type and LOC</comment>
        <createIndex tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_type_loc_id">
            <column name="transaction_type"/>
            <column name="line_of_credit_id"/>
        </createIndex>
    </changeSet>

    <!-- Add index on is_backdated_entry for backdated transaction queries -->
    <changeSet author="crediblex" id="4" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <columnExists tableName="m_line_of_credit_transactions" columnName="is_backdated_entry"/>
                <not>
                    <indexExists tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_backdated"/>
                </not>
            </and>
        </preConditions>
        <comment>Add index for filtering backdated transactions</comment>
        <createIndex tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_backdated">
            <column name="line_of_credit_id"/>
            <column name="is_backdated_entry"/>
        </createIndex>
    </changeSet>

    <!-- Add loan_id and loan_transaction_id columns to transactions table for better traceability (if not exists) -->
    <changeSet author="crediblex" id="5" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <not>
                    <columnExists tableName="m_line_of_credit_transactions" columnName="loan_id"/>
                </not>
            </and>
        </preConditions>
        <comment>Add loan_id and loan_transaction_id to transactions table for better traceability and querying</comment>
        <addColumn tableName="m_line_of_credit_transactions">
            <column name="loan_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="loan_transaction_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add foreign key for loan_id in transactions table -->
    <changeSet author="crediblex" id="6" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <tableExists tableName="m_loan"/>
                <columnExists tableName="m_line_of_credit_transactions" columnName="loan_id"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyName="FK_loc_txn_loan"/>
                </not>
            </and>
        </preConditions>
        <comment>Add foreign key constraint for loan_id in LOC transactions</comment>
        <addForeignKeyConstraint baseTableName="m_line_of_credit_transactions"
                                 baseColumnNames="loan_id"
                                 constraintName="FK_loc_txn_loan"
                                 referencedTableName="m_loan"
                                 referencedColumnNames="id"
                                 onDelete="SET NULL"
                                 onUpdate="RESTRICT"/>
    </changeSet>

    <!-- Add foreign key for loan_transaction_id in transactions table -->
    <changeSet author="crediblex" id="6a" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <tableExists tableName="m_loan_transaction"/>
                <columnExists tableName="m_line_of_credit_transactions" columnName="loan_transaction_id"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyName="FK_loc_txn_loan_transaction"/>
                </not>
            </and>
        </preConditions>
        <comment>Add foreign key constraint for loan_transaction_id in LOC transactions</comment>
        <addForeignKeyConstraint baseTableName="m_line_of_credit_transactions"
                                 baseColumnNames="loan_transaction_id"
                                 constraintName="FK_loc_txn_loan_transaction"
                                 referencedTableName="m_loan_transaction"
                                 referencedColumnNames="id"
                                 onDelete="SET NULL"
                                 onUpdate="RESTRICT"/>
    </changeSet>

    <!-- Add index on loan_id for transaction queries by loan -->
    <changeSet author="crediblex" id="7" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <columnExists tableName="m_line_of_credit_transactions" columnName="loan_id"/>
                <not>
                    <indexExists tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_loan_id"/>
                </not>
            </and>
        </preConditions>
        <comment>Add index on loan_id for efficient queries by loan</comment>
        <createIndex tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_loan_id">
            <column name="loan_id"/>
        </createIndex>
    </changeSet>

    <!-- Add index on loan_transaction_id for direct transaction linking -->
    <changeSet author="crediblex" id="7a" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <columnExists tableName="m_line_of_credit_transactions" columnName="loan_transaction_id"/>
                <not>
                    <indexExists tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_loan_transaction_id"/>
                </not>
            </and>
        </preConditions>
        <comment>Add index on loan_transaction_id for efficient queries by loan transaction</comment>
        <createIndex tableName="m_line_of_credit_transactions" indexName="idx_loc_txn_loan_transaction_id">
            <column name="loan_transaction_id"/>
        </createIndex>
    </changeSet>

    <!-- Add consumed_amount_before and consumed_amount_after to transactions for audit trail -->
    <changeSet author="crediblex" id="8" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <not>
                    <columnExists tableName="m_line_of_credit_transactions" columnName="consumed_amount_before"/>
                </not>
            </and>
        </preConditions>
        <comment>Add consumed amount tracking to transactions for complete audit trail</comment>
        <addColumn tableName="m_line_of_credit_transactions">
            <column name="consumed_amount_before" type="DECIMAL(19,6)">
                <constraints nullable="true"/>
            </column>
            <column name="consumed_amount_after" type="DECIMAL(19,6)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Backfill loan_id from reference_number for existing transactions -->
    <changeSet author="crediblex" id="101" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit_transactions"/>
                <columnExists tableName="m_line_of_credit_transactions" columnName="loan_id"/>
                <columnExists tableName="m_line_of_credit_transactions" columnName="reference_number"/>
            </and>
        </preConditions>
        <comment>Backfill loan_id from reference_number for existing loan-related transactions</comment>
        <sql>
            -- Extract loan_id from reference_number format: "LOAN_{loanId}_{transactionType}"
            -- Uses safe casting with validation to prevent errors from malformed reference_numbers
            -- Only updates if the extracted loan_id exists in m_loan table to avoid FK violations
            UPDATE m_line_of_credit_transactions
            SET loan_id = CAST(
                NULLIF(
                    SUBSTRING(reference_number FROM 'LOAN_([0-9]+)_'),
                    ''
                ) AS BIGINT
            )
            WHERE loan_id IS NULL
              AND reference_number IS NOT NULL
              AND reference_number LIKE 'LOAN_%'
              AND reference_number ~ '^LOAN_[0-9]+_'
              AND SUBSTRING(reference_number FROM 'LOAN_([0-9]+)_') ~ '^[0-9]+$'
              AND EXISTS (
                  SELECT 1 FROM m_loan
                  WHERE id = CAST(
                      NULLIF(
                          SUBSTRING(reference_number FROM 'LOAN_([0-9]+)_'),
                          ''
                      ) AS BIGINT
                  )
              );
        </sql>
    </changeSet>

    <!-- Add comment to consumed_amount column explaining its purpose -->
    <changeSet author="crediblex" id="10" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <tableExists tableName="m_line_of_credit"/>
        </preConditions>
        <comment>Add documentation comments to LOC columns</comment>
        <sql>
            COMMENT ON COLUMN m_line_of_credit.consumed_amount IS
            'Total amount drawn from LOC (sum of all principal_disbursed_derived). Does NOT decrease on repayments, only on reversals/refunds/undo disbursements.';

            COMMENT ON COLUMN m_line_of_credit.available_balance IS
            'Available credit = maximum_amount - consumed_amount. Increases on repayments (credit freed up).';

            COMMENT ON COLUMN m_line_of_credit_transactions.loan_id IS
            'Loan ID associated with this transaction. NULL for non-loan transactions (INCREMENT/DECREMENT).';

            COMMENT ON COLUMN m_line_of_credit_transactions.loan_transaction_id IS
            'Specific loan transaction ID that triggered this LOC transaction. NULL for non-loan transactions or when transaction ID is not available.';
        </sql>
    </changeSet>

</databaseChangeLog>
