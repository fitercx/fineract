<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!-- Add check constraint: consumed amount is non-negative -->
    <changeSet author="crediblex" id="1" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM information_schema.table_constraints
                    WHERE constraint_name = 'chk_loc_consumed_amount_non_negative'
                    AND table_name = 'm_line_of_credit'
                </sqlCheck>
            </and>
        </preConditions>
        <comment>Add check constraint to ensure consumed amount is non-negative</comment>
        <sql>
            <![CDATA[
            ALTER TABLE m_line_of_credit
            ADD CONSTRAINT chk_loc_consumed_amount_non_negative
            CHECK (consumed_amount >= 0);
            ]]>
        </sql>
    </changeSet>

    <!-- Add check constraint: available balance is non-negative -->
    <changeSet author="crediblex" id="1a" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM information_schema.table_constraints
                    WHERE constraint_name = 'chk_loc_available_balance_non_negative'
                    AND table_name = 'm_line_of_credit'
                </sqlCheck>
            </and>
        </preConditions>
        <comment>Add check constraint to ensure available balance is non-negative</comment>
        <sql>
            <![CDATA[
            ALTER TABLE m_line_of_credit
            ADD CONSTRAINT chk_loc_available_balance_non_negative
            CHECK (available_balance >= 0);
            ]]>
        </sql>
    </changeSet>

    <!-- Add check constraint: consumed amount doesn't exceed maximum amount -->
    <changeSet author="crediblex" id="1b" context="postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM information_schema.table_constraints
                    WHERE constraint_name = 'chk_loc_consumed_amount_within_limit'
                    AND table_name = 'm_line_of_credit'
                </sqlCheck>
            </and>
        </preConditions>
        <comment>Add check constraint to ensure consumed amount doesn't exceed maximum amount</comment>
        <sql>
            <![CDATA[
            ALTER TABLE m_line_of_credit
            ADD CONSTRAINT chk_loc_consumed_amount_within_limit
            CHECK (consumed_amount <= maximum_amount);
            ]]>
        </sql>
    </changeSet>

