<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet author="fineract" id="1" >
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not>
                <tableExists tableName="dt_client_remitter_names"/>
            </not>
        </preConditions>

        <createTable tableName="dt_client_remitter_names" >
            <column name="client_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="full_name" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="dt_client_remitter_names"
                baseColumnNames="client_id"
                constraintName="fk_remitter_names_client_id"
                referencedTableName="m_client"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet author="fineract" id="2">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM x_registered_table WHERE registered_table_name = 'dt_client_remitter_names'
            </sqlCheck>
        </preConditions>

        <insert tableName="x_registered_table">
            <column name="registered_table_name" value="dt_client_remitter_names"/>
            <column name="application_table_name" value="m_client"/>
            <column name="entity_subtype" value="Entity"/>
        </insert>
    </changeSet>

    <changeSet author="fineract" id="3" >
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_entity_datatable_check
                WHERE application_table_name = 'm_client' AND x_registered_table_name = 'dt_client_remitter_names'
            </sqlCheck>
        </preConditions>

        <insert tableName="m_entity_datatable_check">
            <column name="application_table_name" value="m_client"/>
            <column name="x_registered_table_name" value="dt_client_remitter_names"/>
            <column name="status_enum" valueNumeric="100"/>
            <column name="system_defined" valueBoolean="false"/>
        </insert>
    </changeSet>

</databaseChangeLog>
