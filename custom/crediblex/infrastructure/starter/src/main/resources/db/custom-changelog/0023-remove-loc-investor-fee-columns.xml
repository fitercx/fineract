<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Drop obsolete invoice handling fee related columns -->
    <changeSet id="1" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="inv_handling_fee_basis"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="inv_handling_fee_basis"/>

    </changeSet>

    <changeSet id="2" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="inv_handling_fee_pct"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="inv_handling_fee_pct"/>

    </changeSet>

    <changeSet id="3" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="inv_handling_fee_min_amount"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="inv_handling_fee_min_amount"/>
    </changeSet>

    <changeSet id="4" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="inv_handling_fee_currency"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="inv_handling_fee_currency"/>

    </changeSet>

    <!-- Drop distribution partner and bank transfer fee columns -->
    <changeSet id="5" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="distribution_partner"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="distribution_partner"/>
    </changeSet>

    <changeSet id="6" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="bank_transfer_fee"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="bank_transfer_fee"/>

    </changeSet>

    <changeSet id="7" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="processing_fee_pct_loc"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="processing_fee_pct_loc"/>

    </changeSet>

    <changeSet id="8" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="is_interest_upfront_or_post_disbursal"/>
            </and>
        </preConditions>
        <modifyDataType tableName="m_line_of_credit" columnName="is_interest_upfront_or_post_disbursal" newDataType="boolean" />

    </changeSet>
    <changeSet id="9" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="name"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="name"/>

    </changeSet>

    <changeSet id="10" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="late_payment_fee"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="late_payment_fee"/>

    </changeSet>

    <changeSet id="11" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="approved_buyers"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="approved_buyers"/>

    </changeSet>

    <changeSet id="12" author="crediblex" context="postgresql">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="m_line_of_credit"/>
                <columnExists tableName="m_line_of_credit" columnName="activated_date"/>
            </and>
        </preConditions>
        <dropColumn tableName="m_line_of_credit" columnName="activated_date"/>

    </changeSet>

</databaseChangeLog>

