<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!-- Step 1: Create the new consolidated dt_client_additional_data table -->
    <changeSet author="fineract" id="1">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not>
                <tableExists tableName="dt_client_additional_data"/>
            </not>
        </preConditions>

        <createTable tableName="dt_client_additional_data">
            <column name="client_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="remitter_names" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="virtual_account_number" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="urn" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="dt_client_additional_data"
                baseColumnNames="client_id"
                constraintName="fk_client_additional_data_client_id"
                referencedTableName="m_client"
                referencedColumnNames="id"/>
    </changeSet>

    <!-- Step 2: Migrate data from existing tables -->
    <changeSet author="fineract" id="2">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="dt_client_additional_data"/>
                <or>
                    <tableExists tableName="dt_client_remitter_names"/>
                    <tableExists tableName="dt_client_virtual_account_number"/>
                </or>
            </and>
        </preConditions>

        <!-- Insert data from remitter names table -->
        <sql>
            INSERT INTO dt_client_additional_data (client_id, remitter_names, created_at, updated_at)
            SELECT 
                rn.client_id,
                rn.full_name,
                rn.created_at,
                rn.updated_at
            FROM dt_client_remitter_names rn
        </sql>

        <!-- Update with virtual account numbers where they exist -->
        <sql>
            UPDATE dt_client_additional_data 
            SET 
                virtual_account_number = (
                    SELECT van.virtual_account_number 
                    FROM dt_client_virtual_account_number van 
                    WHERE van.client_id = dt_client_additional_data.client_id
                ),
                updated_at = CASE 
                    WHEN (SELECT van.updated_at FROM dt_client_virtual_account_number van WHERE van.client_id = dt_client_additional_data.client_id) > updated_at 
                    THEN (SELECT van.updated_at FROM dt_client_virtual_account_number van WHERE van.client_id = dt_client_additional_data.client_id)
                    ELSE updated_at
                END
            WHERE EXISTS (
                SELECT 1 FROM dt_client_virtual_account_number van 
                WHERE van.client_id = dt_client_additional_data.client_id
            )
        </sql>

        <!-- Insert records that only exist in virtual account number table -->
        <sql>
            INSERT INTO dt_client_additional_data (client_id, virtual_account_number, created_at, updated_at)
            SELECT 
                van.client_id,
                van.virtual_account_number,
                van.created_at,
                van.updated_at
            FROM dt_client_virtual_account_number van
            WHERE NOT EXISTS (
                SELECT 1 FROM dt_client_additional_data cad 
                WHERE cad.client_id = van.client_id
            )
        </sql>
    </changeSet>

    <!-- Step 3: Register the new table -->
    <changeSet author="fineract" id="3">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM x_registered_table WHERE registered_table_name = 'dt_client_additional_data'
            </sqlCheck>
        </preConditions>

        <insert tableName="x_registered_table">
            <column name="registered_table_name" value="dt_client_additional_data"/>
            <column name="application_table_name" value="m_client"/>
            <column name="entity_subtype" value="Entity"/>
        </insert>
    </changeSet>

    <!-- Step 4: Add entity datatable check for the new table -->
    <changeSet author="fineract" id="4">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_entity_datatable_check
                WHERE application_table_name = 'm_client' AND x_registered_table_name = 'dt_client_additional_data'
            </sqlCheck>
        </preConditions>

        <insert tableName="m_entity_datatable_check">
            <column name="application_table_name" value="m_client"/>
            <column name="x_registered_table_name" value="dt_client_additional_data"/>
            <column name="status_enum" valueNumeric="100"/>
            <column name="system_defined" valueBoolean="false"/>
        </insert>
    </changeSet>

    <!-- Step 5: Add permissions for the new table -->
    <changeSet author="fineract" id="5">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_permission WHERE code = 'CREATE_dt_client_additional_data'
            </sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="datatable" />
            <column name="code" value="CREATE_dt_client_additional_data" />
            <column name="entity_name" value="dt_client_additional_data" />
            <column name="action_name" value="CREATE" />
            <column name="can_maker_checker" valueBoolean="true"/>
        </insert>
    </changeSet>

    <changeSet author="fineract" id="6">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_permission WHERE code = 'CREATE_dt_client_additional_data_CHECKER'
            </sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="datatable" />
            <column name="code" value="CREATE_dt_client_additional_data_CHECKER" />
            <column name="entity_name" value="dt_client_additional_data" />
            <column name="action_name" value="CREATE" />
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>

    <changeSet author="fineract" id="7">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_permission WHERE code = 'READ_dt_client_additional_data'
            </sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="datatable" />
            <column name="code" value="READ_dt_client_additional_data" />
            <column name="entity_name" value="dt_client_additional_data" />
            <column name="action_name" value="READ" />
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>

    <changeSet author="fineract" id="8">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_permission WHERE code = 'UPDATE_dt_client_additional_data'
            </sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="datatable" />
            <column name="code" value="UPDATE_dt_client_additional_data" />
            <column name="entity_name" value="dt_client_additional_data" />
            <column name="action_name" value="UPDATE" />
            <column name="can_maker_checker" valueBoolean="true"/>
        </insert>
    </changeSet>

    <changeSet author="fineract" id="9">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_permission WHERE code = 'UPDATE_dt_client_additional_data_CHECKER'
            </sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="datatable" />
            <column name="code" value="UPDATE_dt_client_additional_data_CHECKER" />
            <column name="entity_name" value="dt_client_additional_data" />
            <column name="action_name" value="UPDATE" />
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>

    <changeSet author="fineract" id="10">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_permission WHERE code = 'DELETE_dt_client_additional_data'
            </sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="datatable" />
            <column name="code" value="DELETE_dt_client_additional_data" />
            <column name="entity_name" value="dt_client_additional_data" />
            <column name="action_name" value="DELETE" />
            <column name="can_maker_checker" valueBoolean="true"/>
        </insert>
    </changeSet>

    <changeSet author="fineract" id="11">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_permission WHERE code = 'DELETE_dt_client_additional_data_CHECKER'
            </sqlCheck>
        </preConditions>
        <insert tableName="m_permission">
            <column name="grouping" value="datatable" />
            <column name="code" value="DELETE_dt_client_additional_data_CHECKER" />
            <column name="entity_name" value="dt_client_additional_data" />
            <column name="action_name" value="DELETE" />
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>

    <!-- Step 6: Remove old datatable registrations -->
    <changeSet author="fineract" id="12">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <or>
                <sqlCheck expectedResult="1">
                    SELECT COUNT(*) FROM x_registered_table WHERE registered_table_name = 'dt_client_remitter_names'
                </sqlCheck>
                <sqlCheck expectedResult="1">
                    SELECT COUNT(*) FROM x_registered_table WHERE registered_table_name = 'dt_client_virtual_account_number'
                </sqlCheck>
            </or>
        </preConditions>

        <delete tableName="m_entity_datatable_check">
            <where>application_table_name = 'm_client' AND x_registered_table_name IN ('dt_client_remitter_names', 'dt_client_virtual_account_number')</where>
        </delete>

        <delete tableName="x_registered_table">
            <where>registered_table_name IN ('dt_client_remitter_names', 'dt_client_virtual_account_number')</where>
        </delete>

        <!-- Remove role permission associations first -->
        <delete tableName="m_role_permission">
            <where>permission_id IN (SELECT id FROM m_permission WHERE entity_name IN ('dt_client_remitter_names', 'dt_client_virtual_account_number'))</where>
        </delete>

        <!-- Remove old permissions -->
        <delete tableName="m_permission">
            <where>entity_name IN ('dt_client_remitter_names', 'dt_client_virtual_account_number')</where>
        </delete>
    </changeSet>

    <!-- Step 7: Drop old tables (after data migration) -->
    <changeSet author="fineract" id="13">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="dt_client_additional_data"/>
                <or>
                    <tableExists tableName="dt_client_remitter_names"/>
                    <tableExists tableName="dt_client_virtual_account_number"/>
                </or>
            </and>
        </preConditions>

        <dropTable tableName="dt_client_remitter_names" cascadeConstraints="true"/>
        <dropTable tableName="dt_client_virtual_account_number" cascadeConstraints="true"/>
    </changeSet>

</databaseChangeLog>
