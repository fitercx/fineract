<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!-- Add accrual_month column to monthly accrual audit table -->
    <changeSet author="CredibleX" id="1">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not>
                <columnExists tableName="m_loan_monthly_accrual_job_run_audit" columnName="accrual_month"/>
            </not>
        </preConditions>
        <addColumn tableName="m_loan_monthly_accrual_job_run_audit">
            <column name="accrual_month" type="date"/>
        </addColumn>
    </changeSet>

    <!-- Backfill accrual_month from generated_on_date for existing rows -->
    <changeSet author="CredibleX" id="2">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <columnExists tableName="m_loan_monthly_accrual_job_run_audit" columnName="accrual_month"/>
        </preConditions>
        <update tableName="m_loan_monthly_accrual_job_run_audit">
            <column name="accrual_month" valueDate="1970-01-01"/>
            <where>1 = 0</where>
        </update>
        <sql>
            UPDATE m_loan_monthly_accrual_job_run_audit
            SET accrual_month = date_trunc('month', generated_on_date)::date
            WHERE accrual_month IS NULL;
        </sql>
    </changeSet>

    <!-- Make accrual_month not null (uniqueness to be added after data cleanup) -->
    <changeSet author="CredibleX" id="3">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <columnExists tableName="m_loan_monthly_accrual_job_run_audit" columnName="accrual_month"/>
        </preConditions>
        <addNotNullConstraint tableName="m_loan_monthly_accrual_job_run_audit"
                              columnName="accrual_month"
                              columnDataType="date"/>
    </changeSet>

</databaseChangeLog>
