<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet author="crediblex" id="1">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_loan" columnName="line_of_credit_id" />
            </not>
        </preConditions>
        
        <!-- Add the line_of_credit_id column -->
        <addColumn tableName="m_loan">
            <column name="line_of_credit_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet author="crediblex" id="2">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="FK_loan_line_of_credit" />
            </not>
        </preConditions>
        
        <!-- Add foreign key constraint -->
        <addForeignKeyConstraint 
            baseTableName="m_loan" 
            baseColumnNames="line_of_credit_id" 
            constraintName="FK_loan_line_of_credit" 
            referencedTableName="m_line_of_credit" 
            referencedColumnNames="id"
            onDelete="SET NULL"
            onUpdate="CASCADE"/>
    </changeSet>

    <changeSet author="crediblex" id="3">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists tableName="m_loan" indexName="idx_loan_line_of_credit_id" />
            </not>
        </preConditions>
        
        <!-- Add index for performance -->
        <createIndex tableName="m_loan" indexName="idx_loan_line_of_credit_id">
            <column name="line_of_credit_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog> 