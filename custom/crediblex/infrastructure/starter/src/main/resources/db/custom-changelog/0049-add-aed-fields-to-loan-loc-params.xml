<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- Add invoice_amount_in_aed column -->
    <changeSet id="add-invoice-amount-in-aed-column" author="crediblex">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="m_loan_line_of_credit_params"/>
            <not>
                <columnExists tableName="m_loan_line_of_credit_params" columnName="invoice_amount_in_aed"/>
            </not>
        </preConditions>
        <addColumn tableName="m_loan_line_of_credit_params">
            <column name="invoice_amount_in_aed" type="DECIMAL(19,6)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

