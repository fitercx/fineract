<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!--
        Update cron expressions for loan-related jobs to prevent concurrent execution and deadlocks.

        Problem: Multiple jobs were running at the same time (00:00:00 and 00:01:00), causing database
        deadlocks when updating the m_loan table and its associations.

        Solution: Shift the execution TIMES only - frequency remains DAILY (unchanged). Jobs that were
        running at midnight (00:00:00) or 00:01:00 are now staggered across different hours to prevent
        concurrent execution.

        IMPORTANT UPDATE: Based on actual processing times observed:
        - Apply penalty to overdue loans: Takes 2.5-3.5 hours for portfolios with high installment counts
        - All dependent jobs must start AFTER penalty job completes to prevent overlap and deadlocks

        IMPORTANT: All jobs still run ONCE PER DAY - only the TIME of execution is changed.
        Example: If a job was running at 12:00 AM daily, it now runs at 4:00 AM daily (still daily, just different time).

        Schedule (all jobs run daily, times shifted to prevent overlap):
        1. Loan COB: 00:00:00 (unchanged - runs first, most critical, can take 30-60+ min for large portfolios)
        2. Apply penalty to overdue loans: 01:00:00 (was 00:00:00, shifted to 1 AM - takes 2.5-3.5 hours, finishes ~04:30)
        3. Update Loan Arrears Ageing: 04:30:00 (was 01:30:00, shifted to 4:30 AM - runs AFTER penalties complete, includes them in arrears calculation, provides data for other jobs)
        4. Update Non Performing Assets: 05:00:00 (was 02:00:00, shifted to 5 AM - depends on arrears data, 30 min buffer after arrears ageing)
        5. Recalculate Interest For Loans: 05:30:00 (was 02:30:00, shifted to 5:30 AM - depends on arrears ageing, 30 min buffer after NPA)
        6. Transfer Fee For Loans From Savings: 06:00:00 (was 03:00:00, shifted to 6 AM - independent operation, 30 min buffer)
        7. Add Accrual Transactions: 06:30:00 (was 03:30:00, shifted to 6:30 AM - depends on loan state, 30 min buffer)
        8. Add Accrual Transactions For Loans With Income Posted As Transactions: 07:00:00 (was 04:00:00, shifted to 7 AM - final accrual step, 30 min buffer)

        Note: Updated schedule accounts for actual penalty job processing time (2.5-3.5 hours) with 30-minute safety buffers.
        Frequency remains daily for all jobs.
    -->

    <changeSet author="crediblex" id="update-loan-cob-schedule" context="postgresql,mysql">
        <comment>Update Loan COB job schedule to 00:00:00 (keep as first job)</comment>
        <update tableName="job">
            <column name="cron_expression" value="0 0 0 * * ?"/>
            <where>name='Loan COB'</where>
        </update>
    </changeSet>

    <changeSet author="crediblex" id="update-penalty-job-schedule" context="postgresql,mysql">
        <comment>Update Apply penalty to overdue loans job schedule to 01:00:00 (1 hour after COB, runs BEFORE arrears ageing so penalties are included in arrears calculation)</comment>
        <update tableName="job">
            <column name="cron_expression" value="0 0 1 * * ?"/>
            <where>name='Apply penalty to overdue loans'</where>
        </update>
    </changeSet>

    <changeSet author="crediblex" id="update-arrears-ageing-job-schedule" context="postgresql,mysql">
        <comment>Update Update Loan Arrears Ageing job schedule to 04:30:00 (runs AFTER penalty job completes - penalty job takes 2.5-3.5 hours and finishes ~04:30, includes penalties in arrears calculation, provides data for other jobs)</comment>
        <update tableName="job">
            <column name="cron_expression" value="0 30 4 * * ?"/>
            <where>name='Update Loan Arrears Ageing'</where>
        </update>
    </changeSet>

    <changeSet author="crediblex" id="update-npa-job-schedule" context="postgresql,mysql">
        <comment>Update Update Non Performing Assets job schedule to 05:00:00 (30 minutes after arrears ageing at 04:30, depends on arrears data)</comment>
        <update tableName="job">
            <column name="cron_expression" value="0 0 5 * * ?"/>
            <where>name='Update Non Performing Assets'</where>
        </update>
    </changeSet>

    <changeSet author="crediblex" id="update-recalculate-interest-job-schedule" context="postgresql,mysql">
        <comment>Update Recalculate Interest For Loans job schedule to 05:30:00 (30 minutes after NPA at 05:00, depends on arrears ageing)</comment>
        <update tableName="job">
            <column name="cron_expression" value="0 30 5 * * ?"/>
            <where>name='Recalculate Interest For Loans'</where>
        </update>
    </changeSet>

    <changeSet author="crediblex" id="update-transfer-fee-job-schedule" context="postgresql,mysql">
        <comment>Update Transfer Fee For Loans From Savings job schedule to 06:00:00 (30 minutes after interest recalculation at 05:30, independent operation)</comment>
        <update tableName="job">
            <column name="cron_expression" value="0 0 6 * * ?"/>
            <where>name='Transfer Fee For Loans From Savings'</where>
        </update>
    </changeSet>

    <changeSet author="crediblex" id="update-accrual-entries-job-schedule" context="postgresql,mysql">
        <comment>Update Add Accrual Transactions job schedule to 06:30:00 (30 minutes after transfer fee at 06:00, depends on loan state)</comment>
        <update tableName="job">
            <column name="cron_expression" value="0 30 6 * * ?"/>
            <where>name='Add Accrual Transactions'</where>
        </update>
    </changeSet>

    <changeSet author="crediblex" id="update-accrual-entries-loans-income-job-schedule" context="postgresql,mysql">
        <comment>Update Add Accrual Transactions For Loans With Income Posted As Transactions job schedule to 07:00:00 (30 minutes after accrual entries at 06:30, final accrual step)</comment>
        <update tableName="job">
            <column name="cron_expression" value="0 0 7 * * ?"/>
            <where>name='Add Accrual Transactions For Loans With Income Posted As Transactions'</where>
        </update>
    </changeSet>

</databaseChangeLog>
