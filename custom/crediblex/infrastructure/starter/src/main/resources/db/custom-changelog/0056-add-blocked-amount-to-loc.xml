<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!--
        Add blocked_amount column to m_line_of_credit.
        This column allows ops/credit teams to administratively reserve a portion of the
        credit limit, reducing the available amount for borrowers.

        New formula: Available Amount = Credit Limit - Blocked Amount - Consumed Amount
    -->
    <changeSet id="0056-add-blocked-amount-to-loc" author="CredibleX">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_line_of_credit" columnName="blocked_amount"/>
            </not>
        </preConditions>
        <comment>Add blocked_amount column to m_line_of_credit to support administrative reservation of credit limit</comment>
        <addColumn tableName="m_line_of_credit">
            <column name="blocked_amount" type="DECIMAL(19,6)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add permissions for block/unblock actions on line of credit -->
    <changeSet id="0056-add-block-unblock-loc-permissions" author="CredibleX">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_permission WHERE code = 'BLOCKAMOUNT_LINE_OF_CREDIT'
            </sqlCheck>
        </preConditions>
        <comment>Add permissions for block and unblock amount actions on Line of Credit</comment>
        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="BLOCKAMOUNT_LINE_OF_CREDIT"/>
            <column name="entity_name" value="LINE_OF_CREDIT"/>
            <column name="action_name" value="BLOCKAMOUNT"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
        <insert tableName="m_permission">
            <column name="grouping" value="portfolio"/>
            <column name="code" value="UNBLOCKAMOUNT_LINE_OF_CREDIT"/>
            <column name="entity_name" value="LINE_OF_CREDIT"/>
            <column name="action_name" value="UNBLOCKAMOUNT"/>
            <column name="can_maker_checker" valueBoolean="false"/>
        </insert>
    </changeSet>

</databaseChangeLog>
