<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet author="fineract" id="1_add_loan_remitter_dp_info_table">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not>
                <tableExists tableName="dt_loan_remitter_dp_info"/>
            </not>
        </preConditions>

        <createTable tableName="dt_loan_remitter_dp_info">
            <column name="loan_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="remitter_name" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="dp_name" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="dpd" type="DATE">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="dt_loan_remitter_dp_info"
                baseColumnNames="loan_id"
                constraintName="fk_loan_remitter_dp_info_loan_id"
                referencedTableName="m_loan"
                referencedColumnNames="id"/>
    </changeSet>

    <changeSet author="fineract" id="2_register_loan_remitter_dp_info_table">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM x_registered_table WHERE registered_table_name = 'dt_loan_remitter_dp_info'
            </sqlCheck>
        </preConditions>

        <insert tableName="x_registered_table">
            <column name="registered_table_name" value="dt_loan_remitter_dp_info"/>
            <column name="application_table_name" value="m_loan"/>
            <column name="entity_subtype" value="Entity"/>
        </insert>
    </changeSet>

    <changeSet author="fineract" id="3_link_loan_remitter_dp_info_to_entity_datatable_check">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM m_entity_datatable_check
                WHERE application_table_name = 'm_loan' AND x_registered_table_name = 'dt_loan_remitter_dp_info'
            </sqlCheck>
        </preConditions>

        <insert tableName="m_entity_datatable_check">
            <column name="application_table_name" value="m_loan"/>
            <column name="x_registered_table_name" value="dt_loan_remitter_dp_info"/>
            <column name="status_enum" valueNumeric="100"/>
            <column name="system_defined" valueBoolean="false"/>
        </insert>
    </changeSet>

</databaseChangeLog>
