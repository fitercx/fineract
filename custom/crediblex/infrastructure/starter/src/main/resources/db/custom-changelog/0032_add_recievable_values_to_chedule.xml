<?xml version="1.0" encoding="UTF-8"?>
<!--
  Adds is_backdated_entry column to m_line_of_credit_transactions with default false
-->
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="1" author="crediblex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="m_loan_repayment_schedule" columnName="principal_receivable_completed_derived"/>
            </not>
        </preConditions>
        <addColumn tableName="m_loan_repayment_schedule">
            <column name="principal_receivable_expected" type="DECIMAL(19,6)">
            </column>
            <column name="principal_receivable_completed_derived" type="DECIMAL(19,6)">
            </column>
            <column name="interest_receivable_completed_derived" type="DECIMAL(19,6)">
            </column>
        </addColumn>

    </changeSet>

</databaseChangeLog>
