<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="0055-create-note-document-mapping-table" author="crediblex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="cx_note_document"/>
            </not>
        </preConditions>

        <createTable tableName="cx_note_document">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="note_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="document_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="display_order" type="INT" defaultValueNumeric="0"/>
            <column name="created_date" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="cx_note_document"
                                 baseColumnNames="note_id"
                                 constraintName="fk_note_document_note"
                                 referencedTableName="m_note"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <addForeignKeyConstraint baseTableName="cx_note_document"
                                 baseColumnNames="document_id"
                                 constraintName="fk_note_document_document"
                                 referencedTableName="m_document"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <addUniqueConstraint tableName="cx_note_document"
                             columnNames="note_id,document_id"
                             constraintName="uk_note_document"/>

        <createIndex tableName="cx_note_document" indexName="idx_note_document_note_id">
            <column name="note_id"/>
        </createIndex>

        <createIndex tableName="cx_note_document" indexName="idx_note_document_document_id">
            <column name="document_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
