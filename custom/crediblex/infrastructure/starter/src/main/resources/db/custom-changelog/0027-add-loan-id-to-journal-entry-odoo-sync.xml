<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet author="crediblex" id="46">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="journal_entry_odoo_sync"/>
            <not>
                <columnExists tableName="journal_entry_odoo_sync" columnName="loan_id"/>
            </not>
        </preConditions>
        <comment>Add loan_id column to journal_entry_odoo_sync table for grouping entries by loan</comment>
        <addColumn tableName="journal_entry_odoo_sync">
            <column name="loan_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet author="crediblex" id="47">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="journal_entry_odoo_sync"/>
            <tableExists tableName="m_loan"/>
            <columnExists tableName="journal_entry_odoo_sync" columnName="loan_id"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_journal_entry_odoo_sync_loan_id"/>
            </not>
        </preConditions>
        <comment>Add foreign key constraint from journal_entry_odoo_sync.loan_id to m_loan.id</comment>
        <addForeignKeyConstraint baseTableName="journal_entry_odoo_sync"
                                 baseColumnNames="loan_id"
                                 constraintName="fk_journal_entry_odoo_sync_loan_id"
                                 referencedTableName="m_loan"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet author="crediblex" id="48">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="journal_entry_odoo_sync"/>
            <columnExists tableName="journal_entry_odoo_sync" columnName="loan_id"/>
            <not>
                <indexExists tableName="journal_entry_odoo_sync" indexName="idx_journal_entry_odoo_sync_loan_id"/>
            </not>
        </preConditions>
        <comment>Add index on loan_id for better query performance</comment>
        <createIndex tableName="journal_entry_odoo_sync" indexName="idx_journal_entry_odoo_sync_loan_id">
            <column name="loan_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
